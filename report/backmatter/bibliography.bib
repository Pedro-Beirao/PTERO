	doi = {10.3390/encyclopedia5010018},
	abstract = {The Likert-type scale is a widely used psychometric instrument for measuring attitudes, opinions, or perceptions in research contexts. It presents respondents with a series of statements accompanied by symmetrical response options, typically structured on a five-point scale ranging from “Strongly Disagree” to “Strongly Agree”. Each point on the scale represents a gradation of agreement or sentiment, allowing researchers to transform subjective responses into quantifiable data for statistical analysis and interpretation.},
