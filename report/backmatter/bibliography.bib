@article{bencherki_landscape_2026,
	title = {The landscape of {IEC} 61499 in modern automation: {A} scoping review of research trends and gaps (2018–2025)},
	volume = {162},
	issn = {0959-1524},
	shorttitle = {The landscape of {IEC} 61499 in modern automation},
	url = {https://www.sciencedirect.com/science/article/pii/S0959152426001095},
	doi = {10.1016/j.jprocont.2026.103726},
	abstract = {Purpose
— IEC 61499 has been proposed as a basis for distributed and flexible control in Industry 4.0. This study maps the IEC 61499 research landscape from 2018 to 2025, characterizing dominant themes, emerging directions, and the standard’s practical readiness for cyber–physical systems.
Design/methodology/approach
— We conducted a PRISMA-ScR scoping review across IEEE Xplore, Scopus, ScienceDirect, and SpringerLink. This resulted in a corpus of 373 peer-reviewed papers. The studies were coded into thematic clusters and further analyzed to distinguish between conceptual work and implemented systems and real-world deployments. Particular attention was given to migration/coexistence, Intelligent Automation and Advanced Control, and industrial applications.
Findings
— The corpus is dominated by engineering methods and Operational Technology/Information Technology (OT/IT) integration, indicating that research has shifted from replacing PLC logic to enabling interoperable, distributed architectures. AI-related work forms an emerging, sustained stream focused on embedding learning components into function-block-based control. However, validation remains largely prototype-oriented, and only a small percentage of studies report deployments in realistic industrial settings. This reveals a clear deployment gap: the main bottleneck is no longer conceptual feasibility, but scalable, benchmarked, and sustained validation under industrial constraints.
Originality/value
— This review provides an up-to-date thematic and maturity map of post-2018 IEC 61499 research. It clarifies where progress is concentrated and where barriers to industrial adoption persist, notably migration, cybersecurity, and high-fidelity industrial validation.},
	urldate = {2026-06-15},
	journal = {Journal of Process Control},
	author = {Bencherki, Zakaria and Benfriha, Khaled and Meyrueis, Vincent and Sava, Alexandre and Soares, Philippe and Cachot, Laurent},
	month = jun,
	year = {2026},
	keywords = {Cyber–physical systems, Distributed control, IEC 61499, Industrial automation, Research gaps, Scoping review},
	pages = {103726},
	file = {ScienceDirect Full Text PDF:/Users/pedro/Zotero/storage/8M5NDV23/Bencherki et al. - 2026 - The landscape of IEC 61499 in modern automation A scoping review of research trends and gaps (2018–.pdf:application/pdf;ScienceDirect Snapshot:/Users/pedro/Zotero/storage/4GGLT3QT/S0959152426001095.html:text/html},
}

@article{lewis_item_2018,
	title = {Item {Benchmarks} for the {System} {Usability} {Scale}},
	volume = {13},
	abstract = {From humble beginnings, the SUS has become a valuable tool in the toolkits of usability and user experience practitioners and researchers. We have developed regression equations that compute benchmarks for SUS items based on an overall SUS score. A review of the SUS literature on published benchmarks for the means of overall SUS scores from usability studies/surveys provides guidance on selecting an appropriate value of SUS to use when setting item benchmarks. We expect this extension of SUS benchmarking methodology to be of value to usability and user experience practitioners.},
	author = {Lewis, James and Sauro, Jeff},
	month = may,
	year = {2018},
	pages = {158--167},
	file = {Full Text PDF:/Users/pedro/Zotero/storage/YTIGYFI5/Lewis and Sauro - 2018 - Item Benchmarks for the System Usability Scale.pdf:application/pdf},
}

