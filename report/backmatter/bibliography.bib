	file = {PDF:/Users/pedro/Zotero/storage/KKVDV3ZS/Rohat and Popescu - 2014 - Web System for the Remote Control and Execution of an IEC 61499 Application.pdf:application/pdf},
}

@incollection{moreno-diaz_iec_2020,
